# Database (Supabase project)
DATABASE_URL=postgres://postgres:password@db.xxx.supabase.co:5432/postgres
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Meta Marketing API (agency Business Manager system user)
META_SYSTEM_USER_TOKEN=
META_GRAPH_API_VERSION=v21.0

# Shared Google Cloud OAuth client (Web application), used by both GA4 and
# Google Ads below. Redirect URIs registered on it: /api/admin/integrations/ga4/callback
# for localhost, the Railway domain, and the production custom domain.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Google Ads API (agency MCC)
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# GA4 Data API: agency-level OAuth sign-in (lib/ga4-oauth.ts), not a service
# account. The resulting refresh token is stored in agency_integrations.external_ref,
# not an env var.

# Anthropic (daily anomaly narratives)
ANTHROPIC_API_KEY=

# Web app
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Revalidation handshake between daily job and web app
REVALIDATE_SECRET=

# Signs the session cookie (see apps/web/lib/auth.ts). Required in any
# shared/production environment; local dev falls back to an insecure
# constant if unset. Generate with: openssl rand -hex 32
SESSION_SECRET=
